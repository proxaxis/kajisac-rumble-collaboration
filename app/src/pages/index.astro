---
import Layout from '@/layouts/Layout.astro';
import '@/styles/global.scss';
---

<Layout>
  <div class="key-visual">
    <h1>Make the world tremendous</h1>
    <a href="#one">Get Started</a>
  </div>

  <main>
    <section id="one">
      <h2>INTRODUCE</h2>
      <hr />
      <p>
        どうも、カジサックです。<br />
        ここでは、私の作品を紹介しています。<br />
        ご興味があれば、ぜひご覧ください。
      </p>
    </section>

    <section id="two">
      <h2>HIGHLIGHTS</h2>
      <hr />
      <ul class="gallery">
        <li>
          <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcT1FNqZQ3RetNnZCxRAv4jk4hGn1zo-VZSFCA&usqp=CAU" />
          <p>
            <span><a href="https://www.youtube.com/watch?v=zjpc5CTFMW0">梶原雄太の家<br />大公開大合掌大射精<br /></a></span>
            <span>Make new world Project</span>
          </p>
        </li>

        <li>
          <img src="https://blog.esrij.com/arcgisblog/wp-content/uploads/2018/10/1-1.png" />
          <p>
            <span>カジサック</span>
            <span>吉本</span>
          </p>
        </li>

        <li>
          <img src="https://artna.jp/wp-content/uploads/2019/07/art-of-europe06-680x453.jpg" />
          <p>
            <span>New releace</span>
            <span class="text-muted">Enjoy his new theme</span>
          </p>
        </li>
      </ul>
    </section>
  </main>
</Layout>

<style lang="scss">
  .key-visual {
    position: relative;
    width: 100%;
    height: 100vh;
    background-image: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e');
    background-size: cover;
    background-position: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;

    h1 {
      font-size: 3rem;
      margin-bottom: 1rem;
    }

    a {
      font-size: 1.25rem;
      padding: 0.75rem 1.5rem;
      border: 1px solid var(--accent);
      border-radius: 10px;
      transition: background-color 0.3s ease;

      &:hover {
        background-color: var(--accent);
        color: var(--text-light);
      }
    }
  }

  main p {
    text-align: center;
  }

  .gallery {
    display: flex;
    flex-wrap: nowrap;
    height: 16rem;
    gap: 0.5rem;

    li {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: space-between;

      flex: 1 0;

      img {
        width: 100%;
      }

      p {
        text-align: center;

        span {
          display: block;
          margin-bottom: 0.5rem;
        }

        .text-muted {
          color: var(--text-muted);
        }
      }
    }
  }
</style>
