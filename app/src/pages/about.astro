---
import Layout from '@/layouts/Layout.astro';
import '@/styles/about-style.css';
---

<Layout>
  <section>
    <!-- Information -->
    <div class="container" id="information">
      <div class="row">
        <div class="col-lg-12 text-center">
          <h2 class="margin-top-0 text-primary">INFORMATION</h2>
          <hr class="primary" />
        </div>
      </div>
    </div>
    <div class="container">
      <div class="row">
        <div class="col-lg-12 col-md-12 text-left about-element" id="developpers">
          <h2>Developpers</h2>
          <p>Hello everyone</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <div class="container" id="about">
    <div class="row">
      <div class="col-lg-12 text-center">
        <h2 class="margin-top-0 text-primary">ABOUT</h2>
        <hr class="primary" />
      </div>
    </div>
  </div>
  <div class="container">
    <div class="row">
      <div class="col-lg-12 col-md-12 text-left about-element" id="contactus">
        <h2>Contact Us</h2>
        <form class="contactform" method="post">
          <li><label>Name</label><input type="text" name="yourname" placeholder="Enter your name*" /></li>
          <li><label>Mail</label><input type="text" name="yourmailadress" placeholder="Enter your Email adress*" /></li>
          <li><label>Content</label><textarea name="content"></textarea></li>
          <li class="btn"><input type="submit" name="submit" value="Send" /></li>
        </form>
      </div>
    </div>
  </div>
</Layout>
