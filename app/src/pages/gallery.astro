---
import Layout from '@/layouts/Layout.astro';
---

<Layout>
  <section>
    <div class="container">
      <div class="row">
        <div class="col-lg-12 text-center">
          <h2 class="margin-top-0 text-primary">GALLERY</h2>
          <hr class="primary" />
        </div>
      </div>
    </div>
    <div class="container">
      <div class="row">
        <div class="col-lg-6 col-md-6 text-center">
          <div class="gallery">
            <!-- highlights img = 360px x 240px -->
            <img src="./assets/beach.jpg" />
            <h3>Title</h3>
            <p class="text-muted">Description</p>
          </div>
        </div>
        <div class="col-lg-6 col-md-6 text-center">
          <div class="gallery">
            <img src="https://blog.esrij.com/arcgisblog/wp-content/uploads/2018/10/1-1.png" />
            <h3>For the world end</h3>
            <p class="text-muted">Are you ready for new space?</p>
          </div>
        </div>
        <div class="col-lg-6 col-md-6 text-center">
          <div class="gallery">
            <!-- <i class="icon-lg ion-ios-star-outline wow fadeIn" data-wow-delay=".3s"></i> -->
            <img src="https://artna.jp/wp-content/uploads/2019/07/art-of-europe06-680x453.jpg" />
            <h3>New releace</h3>
            <p class="text-muted">Enjoy his new theme</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
